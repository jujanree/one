{
	"compilerOptions": {
		"rootDir": "../",
		"outDir": "../dist",
		"lib": ["ESNext"],
		"types": ["node"],
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "nodenext",
		"declaration": true,
		"strictNullChecks": true,
		"strict": false
	},
	"include": ["../**/*.ts"],
	"exclude": ["../node_modules", "../tests", "../dist"]
}
