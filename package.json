{
	"name": "@hgargg-0710/one",
	"version": "0.5.0",
	"description": "A utility npm library that provides beautiful solutions to routine tasks over JavaScript types.",
	"keywords": [
		"utils"
	],
	"homepage": "https://github.com/HGARgG-0710/one#readme",
	"bugs": {
		"url": "https://github.com/HGARgG-0710/one/issues"
	},
	"license": "MIT",
	"author": "hgargg-0710",
	"type": "module",
	"main": "./dist/main.js",
	"types": "./dist/main.d.ts",
	"scripts": {
		"build": "npx tsc --project .",
		"test": "cd tests && npx tsc --project . && cd ..",
		"debug": "npx tsc --project ./ts/debug.json",
		"test-debug": "cd tests && npx tsc --project ../ts/test-debug.json && cd ..",
		"all": "npm run build && npm run test",
		"debug-all": "npm run debug && npm run test-debug"
	},
	"devDependencies": {
		"@types/node": "^22.19.19",
		"typescript": "^6.0.3"
	}
}
